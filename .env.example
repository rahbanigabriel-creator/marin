# ──────────────────────────────────────────────────────────────────────────
# Marin — environment configuration
# Copy to `.env.local` and fill in. Milestone 1 (the prototype) needs NONE of
# these; they are scaffolding for the auth + DB + integration phases.
# ──────────────────────────────────────────────────────────────────────────

# ── Auth (Clerk) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Database (Postgres + Prisma) ────────────────────────────────────────────
# Neon (or any Postgres) connection string. Use an EU region for data residency.
# Required by `prisma generate` / `prisma migrate` and by any live DB read.
# When UNSET the app stays green and falls back to canned "Sample" data
# (see isDatabaseConfigured() in src/lib/db.ts).
DATABASE_URL="postgresql://user:password@localhost:5432/marin?schema=public"

# ── Token vault (connected-account OAuth tokens) ────────────────────────────
# AES-256-GCM key for encrypting connector OAuth tokens at rest (Connection
# .encAccessToken / .encRefreshToken). MUST be 32 random bytes, base64-encoded:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leave empty in environments without connectors; never commit a real value.
TOKEN_ENC_KEY=

# ── AI provider ─────────────────────────────────────────────────────────────
# Set this to activate the live agent: /api/chat generates the answer lead with
# Claude (routed Haiku/Sonnet/Opus), grounded in account data. When unset, the
# route falls back to canned leads and the app works unchanged.
ANTHROPIC_API_KEY=
# Optional kill-switch: set to "false" to force canned leads even with a key set.
USE_LIVE_AGENT=

# ── First-party site analytics — GA4 on www.marpin.ai (NOT a client connector) ─
# Measures visitors to the Marpin app/site itself. This is a GA4 *Measurement ID*
# (looks like G-XXXXXXXXXX) from a GA4 web data stream for www.marpin.ai. It is
# public by design and is SEPARATE from the GOOGLE_OAUTH_* connector below (which
# lets *customers* connect *their own* Google accounts). When UNSET, no GA tag loads.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Platform integrations (stubbed in milestone 1; mock provider falls back) ─
# Google Ads / GA4
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
# Meta (Facebook / Instagram) Ads
META_APP_ID=
META_APP_SECRET=
# TikTok Ads
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
# LinkedIn Ads
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Observability — Sentry (errors) ─────────────────────────────────────────
# Set the DSN to activate Sentry error/perf reporting. When UNSET, Sentry never
# initialises (no client, no network) and the build stays green — see
# instrumentation.ts / sentry.server.config.ts / instrumentation-client.ts.
# EU data residency: create the Sentry project in an EU region; events route to
# the region encoded in the DSN (no host hardcoded).
# Server + edge runtime DSN:
SENTRY_DSN=
# Browser DSN (public by design; only authorises event ingestion):
NEXT_PUBLIC_SENTRY_DSN=
# Optional perf trace sample rates (0..1; default 0.1 when a DSN is set):
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
# Build-time source-map upload — set ALL THREE to enable withSentryConfig in
# next.config.ts; otherwise the plain config is used and the build is unchanged.
# Never commit a real auth token.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Observability — PostHog (product analytics) ─────────────────────────────
# Set the project key to activate analytics (server capture() + browser SDK).
# When UNSET, capture() is a no-op, no provider mounts, and nothing loads —
# see src/lib/analytics.ts and src/components/analytics/PostHogProvider.tsx.
# The key is public (NEXT_PUBLIC_) — it only authorises event ingestion.
NEXT_PUBLIC_POSTHOG_KEY=
# EU data residency: defaults to the PostHog EU ingestion host. Only override
# with another EU-region host; never a US endpoint.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Observability — Langfuse (LLM cost tracing) ─────────────────────────────
# Set BOTH keys to activate LLM tracing: each agent answer records a trace +
# per-model-call generation capturing model, tier, input/output token usage, and
# computed USD cost (Haiku $1/$5, Sonnet $3/$15, Opus $5/$25 per 1M tokens).
# When EITHER is unset, tracing is a transparent no-op — the live agent behaves
# byte-identically and the build stays green (see isLlmTracingEnabled() in
# src/lib/observability/llm-trace.ts). Keys are server-only; never commit them.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# EU data residency: defaults to the Langfuse EU cloud host. Only override with
# another EU-region host (e.g. a self-hosted EU instance); never a US endpoint.
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ── Background jobs — Inngest (scheduled + event-driven metric sync) ─────────
# Set BOTH keys to activate background sync: a cron (every 6h) and an
# event-triggered "connection/connected" backfill pull each workspace's
# Connection rows through connector.fetchMetrics → ingestMetrics. When UNSET the
# client runs in dev/no-op mode, the /api/inngest serve endpoint still mounts and
# responds, and nothing throws at import/build — see isInngestConfigured() in
# src/lib/jobs/inngest.ts. Both keys are server-only; never commit them.
#   INNGEST_EVENT_KEY   — authorises sending events to Inngest.
#   INNGEST_SIGNING_KEY — verifies inbound requests to /api/inngest (security:
#                         never disable signature verification in production).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# EU data residency: configure your Inngest account/environment in the EU; the
# event key is bound to that environment (no US host is hardcoded). Optionally
# pin a specific EU ingestion host here; leave empty to use the SDK default.
INNGEST_BASE_URL=

# ── Email / alerts — Resend ─────────────────────────────────────────────────
# Set RESEND_API_KEY to activate transactional alert emails (sendEmail() in
# src/lib/email/resend.ts). When UNSET, sendEmail() is a logged no-op that never
# throws and returns { skipped: true } — so alert-emitting paths stay safe and
# `next build` / `tsc --noEmit` stay green with no env (see isEmailConfigured()).
# EU data residency: configure the Resend account + sending domain in the EU; no
# host is hardcoded. Server-only; never commit.
RESEND_API_KEY=
# Optional default From (must be a Resend-verified sender). Falls back to a
# built-in default when unset, e.g. "Marin Alerts <alerts@yourdomain.eu>".
RESEND_FROM=

# ── Cache / rate-limit — Upstash Redis ──────────────────────────────────────
# Set BOTH the REST URL and token to activate the sliding-window rate limiter
# (e.g. on /api/chat) and the small JSON cache helper (src/lib/cache/redis.ts).
# When EITHER is unset, the rate limiter is a PERMISSIVE no-op (every request
# allowed) and the cache is a pass-through MISS — nothing throws, so the build
# stays green and behaviour is unchanged offline (see isRedisConfigured()).
# EU data residency: create the Upstash database in an EU region; the REST URL is
# bound to that region's endpoint (no host hardcoded). Server-only; never commit.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Billing & metering — Stripe ─────────────────────────────────────────────
# Set STRIPE_SECRET_KEY to activate billing: /api/billing/checkout creates a
# Checkout Session and /api/billing/portal opens the Customer Portal. When UNSET,
# both routes return a graceful 503 and nothing throws at import/build — see
# isBillingConfigured() in src/lib/billing/stripe.ts. Server-only; never commit.
STRIPE_SECRET_KEY=
# Webhook signing secret (Stripe Dashboard → Webhooks → your endpoint). REQUIRED
# for /api/billing/webhook: every event is verified against this secret BEFORE any
# state change (stripe.webhooks.constructEvent). When UNSET the webhook returns 503
# and never trusts an unverified event. Server-only; never commit.
STRIPE_WEBHOOK_SECRET=
# Stripe Price ids (one recurring Price per paid plan, in EUR — see
# docs/pricing-strategy.md §3: Solo €39.99/120cr · Business €149/600cr ·
# Max €599/3000cr). Read lazily per plan (src/lib/billing/plans.ts); a plan with
# no price id configured is simply not checkout-able (checkout returns 503). The
# Free plan has no Stripe price. EU residency is set at the Stripe account level.
STRIPE_PRICE_SOLO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_MAX=

# ── App URL (billing redirects, OAuth callbacks) ────────────────────────────
# Public base URL for Checkout success/cancel + Customer Portal return links.
# When UNSET the route derives the origin from the incoming request (dev-friendly).
APP_URL=
NEXT_PUBLIC_APP_URL=

# ── Feature flags ───────────────────────────────────────────────────────────
# When unset/false the app uses canonical mock data instead of live connectors.
USE_LIVE_CONNECTORS=false
