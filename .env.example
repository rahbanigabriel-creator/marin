# ──────────────────────────────────────────────────────────────────────────
# Marin — environment configuration
# Copy to `.env.local` and fill in. Milestone 1 (the prototype) needs NONE of
# these; they are scaffolding for the auth + DB + integration phases.
# ──────────────────────────────────────────────────────────────────────────

# ── Auth (Clerk) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Database (Postgres + Prisma) ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/marin?schema=public"

# ── AI provider ─────────────────────────────────────────────────────────────
# Set this to activate the live agent: /api/chat generates the answer lead with
# Claude (routed Haiku/Sonnet/Opus), grounded in account data. When unset, the
# route falls back to canned leads and the app works unchanged.
ANTHROPIC_API_KEY=
# Optional kill-switch: set to "false" to force canned leads even with a key set.
USE_LIVE_AGENT=

# ── Platform integrations (stubbed in milestone 1; mock provider falls back) ─
# Google Ads / GA4
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
# Meta (Facebook / Instagram) Ads
META_APP_ID=
META_APP_SECRET=
# TikTok Ads
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
# LinkedIn Ads
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Feature flags ───────────────────────────────────────────────────────────
# When unset/false the app uses canonical mock data instead of live connectors.
USE_LIVE_CONNECTORS=false
